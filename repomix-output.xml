import { useNavigate } from "react-router-dom"
import Button from "../components/Button"
import { useState } from "react"

function Projects() {

const [projects, setProjects] = useState([
  {
    name: "PMS",
    status: "Development",
    priority: "High"
  },

  {
    name: "Portfolio Website",
    status: "Completed",
    priority: "Low"
  }
  ])

  const [name, setName] = useState("")
  const [status, setStatus] = useState("")
  const [priority, setPriority] = useState("")
  const navigate = useNavigate()
  
  function addProject() {

    const newProject = {
      name,
      status,
      priority
    }

    setProjects([...projects, newProject])

    setName("")
    setStatus("")
    setPriority("")
  }


 

  return (
    <div>

      <h1 className="text-5xl font-bold mb-5">
        Projects
      </h1>

      <div className="flex gap-3 mb-5 flex-wrap">

        <input
          type="text"
          placeholder="Project Name"
          value={name}
          onChange={(e) =>
            setName(e.target.value)
          }
          className="
            p-3
            rounded-lg
            bg-slate-700
            text-white
            placeholder-gray-300
            border
            border-slate-600
            outline-none
          "
        />

        <input
          type="text"
          placeholder="Status"
          value={status}
          onChange={(e) =>
            setStatus(e.target.value)
          }
          className="
              p-3
              rounded-lg
              bg-slate-700
              text-white
              placeholder-gray-300
              border
              border-slate-600
              outline-none
              "
        />

        <input
          type="text"
          placeholder="Priority"
          value={priority}
          onChange={(e) =>
            setPriority(e.target.value)
          }
          className="
            p-3
            rounded-lg
            bg-slate-700
            text-white
            placeholder-gray-300
            border
            border-slate-600
            outline-none
          "
        />

        <Button
          text="Add Project"
          onClick={addProject}
        />

      </div>

      <div className="flex gap-5 flex-wrap">

        {
          projects.map((project) => (
            <div
              key={project.name}
              onClick={() =>
                navigate(`/tasks/${project.name}`)
              }
              className="
                bg-slate-800
                text-white
                p-5
                rounded-xl
                w-[250px]
                cursor-pointer
                hover:bg-slate-700
                transition
              "
            >
              <h3 className="text-2xl font-bold">
                {project.name}
              </h3>

              <p className="mt-3">
                Status: {project.status}
              </p>

              <p>
                Priority: {project.priority}
              </p>

            </div>
          ))
        }

      </div>

    </div>
  )
}

export default Projects
